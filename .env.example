# Finovate Pulse — environment variables (compose / Coolify)
# Copy to ".env" for local docker-compose, OR set these in Coolify's UI.
# NEVER commit the real .env file.

# Supabase Postgres (read-only role recommended)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Gemini AI — free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Backend CORS — comma-separated allowed origins, or * for any
ALLOWED_ORIGINS=*

# PUBLIC URL of the backend that the BROWSER will call.
# Local compose:  http://localhost:8000
# Coolify:        https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8000
