# Copy this file to ".env" (this folder) when running the backend directly.
# For Docker/Coolify, set these in the compose env / Coolify UI instead.

# Supabase Postgres — use the Session/Transaction pooler host.
# Dashboard -> Project Settings -> Database -> Connection string -> URI
# A read-only role is recommended so the main password stays untouched.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Gemini AI for the Ask-AI panel. Free key: https://aistudio.google.com/apikey
# Leave GEMINI_API_KEY empty to fall back to the built-in rule engine.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# CORS: comma-separated allowed origins, or * for any.
ALLOWED_ORIGINS=*
